                }
              }
            },
            {
              "name": "knowledge_results",
              "input": {
                "type": "string",
                "value": {
                  "type": "ref",
                  "content": {
                    "source": "block-output",
                    "blockID": "200001",
                    "name": "outputList"
                  }
                }
              }
            }
          ],
          "llmParam": [
            { "name": "modelType", "input": { "type": "string", "value": { "type": "literal", "content": "YOUR_MODEL_TYPE" } } },
            { "name": "modleName", "input": { "type": "string", "value": { "type": "literal", "content": "YOUR_MODEL_NAME" } } },
